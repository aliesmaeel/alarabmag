APP_NAME="مجلة العرب"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alarab_magazine
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

ADMIN_USER=admin
ADMIN_PASS=alarab2026

# AI writing assistant (free — open-source models, not OpenAI paid API)
# Get a free key: https://console.groq.com
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_TIMEOUT=45
AI_ARTICLE_TIMEOUT=120
# Alternatives (also free):
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Web search for «توليد مقال كامل» (optional — better results than DuckDuckGo alone)
# Recommended free: https://tavily.com (1000 searches/month, no card required)
TAVILY_API_KEY=
# Brave Search API is NOT fully free (requires card, ~$5 credits/month then paid)
# BRAVE_SEARCH_API_KEY=
# AI_WEB_SEARCH_PROVIDER=auto
